# Local .terraform directories
**/.terraform/*

# Terraform lockfile (commit this)
!.terraform.lock.hcl

# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Sensitive variable files — NEVER commit
*.tfvars.backup
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
